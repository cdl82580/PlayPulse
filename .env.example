# ----------------------------------------------------------------------------
# PlayPulse — environment template. Copy to `.env` for local dev and fill in.
# NEVER commit real secrets. Real values live in `.env` (gitignored) locally
# and in Vercel's per-environment settings (Development / Production) in cloud.
# ----------------------------------------------------------------------------

# Node environment
NODE_ENV=development

# --- PostgreSQL (Neon) -------------------------------------------------------
# DATABASE_URL: pooled connection (Neon "Pooled connection" string, ?sslmode=require).
#   Used by the app at runtime.
# DIRECT_URL:   unpooled/direct connection. Used by `prisma migrate`.
# Use the Neon `dev` branch locally and for the Development env; the `main`
# branch for Production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/playpulse?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/playpulse?sslmode=require"

# --- Redis (Upstash) ---------------------------------------------------------
# Cache + realtime pub/sub. Use the rediss:// (TLS) URL from Upstash.
REDIS_URL="rediss://default:PASSWORD@HOST.upstash.io:6379"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
